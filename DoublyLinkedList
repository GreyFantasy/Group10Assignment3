    private Node<T>? head;
    private Node<T>? tail; // For later in the lab



    public LinkedList()
    {
        head = null;
        tail = null; //added tail with no value (used to track last node)
    }

    // Adds a new element to the front of the list.
    public void AddFront(T toAdd)
    {
        Node<T> newNode = new Node<T>(toAdd);

        if (head == null) //checks if head is null then head == tails
        {
            head = newNode;
            tail = newNode;
            return;
        }
        
        newNode.next = head;
        head = newNode;
    }

    // Adds a new element to the back of the list.
    public void AddBack(T toAdd)
    {
        // Note: `ToStringForward` shows how to traverse a LinkedList.

        Node<T> newNode = new Node<T>(toAdd);

        if (head == null) //checks if the list is empty at point
        {
            head = newNode; //if so then the new node becomes the firs node
            tail = newNode; // on first insertion head == tail
            return;
        }


        tail.next = newNode; //connects tail to new node
        tail = newNode; // moves the tail 
    } 

    // Removes the first node from the list and returns its data.
    public T? RemoveFront()
    {
        if (head == null)
            return default;
            
        T data = head.data;
        head = head.next;

        if (head == null)
        tail = null;

        return data;
    }


    // Removes the last node from the list and returns its data.
     public T? RemoveBack()
    {
        // Note: keep in mind that removing the last node requires a reference
        // to the *second* last node.

        if (head == null) //if the list is empty then return default
        return default;

        if (head == tail) //check if only one node exists
        {
            T data = head.data; //Save the data and delete the node 
            head = null; //head and tail are both the same node so they are both null
            tail = null;
            return data;
        }

        Node<T>? curr = head; 

        while (curr.next != tail) //stops at second to last node (stop if two pos from curr are null)
        {
            curr = curr.next;
        }

        T removedData = tail.data; //store the remove data 
        tail = curr;
        tail.next = null; //remove the last node

        return removedData;
    } 
    

    public bool Find(T toFind)
    {
        var comparer = EqualityComparer<T>.Default;

        Node<T>? curr = head;
        while (curr != null)
        {
            if (comparer.Equals(curr.data, toFind))
                return true;
            curr = curr.next;
        }

        return false;
    }

